# Copiază în .env și completează
PORT=4000
JWT_SECRET=pune-aici-un-string-lung-si-random-pentru-productie
# În dev lasă http://localhost:5173 (Vite). În prod pune domeniul tău, separat prin virgulă dacă ai mai multe.
FRONTEND_ORIGIN=http://localhost:5173
# MongoDB connection string (Atlas sau local)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/news?retryWrites=true&w=majority
